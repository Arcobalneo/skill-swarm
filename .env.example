# ============================================================
# Forge Skill Swarm Backend — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
PORT=8000
HOST=0.0.0.0

# --- API Keys (Required) ---
DEEPSEEK_API_KEY=your-deepseek-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# --- Data & Persistence ---
# DATA_DIR=/app/data
# DATABASE_PATH=/app/data/db/tasks.db
# WORKSPACE_ROOT=/app/data/tasks

# --- Execution Limits ---
# DEFAULT_TIMEOUT_MS=1800000
# MAX_CONCURRENT_TASKS=10

# --- Workspace Cleanup ---
# WORKSPACE_MAX_AGE_DAYS=30
# WORKSPACE_MAX_COUNT=1000
# CLEANUP_INTERVAL_MS=86400000

# --- Logging ---
# LOG_LEVEL=info
