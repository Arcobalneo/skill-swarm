# ==========================================
# Skill Swarm Backend - Environment
# ==========================================

# --- Required ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
GEMINI_API_KEY=sk-your-gemini-api-key

# --- Server ---
PORT=8000
HOST=0.0.0.0

# --- Model Configuration (all optional, defaults to DeepSeek official API) ---
# Execution model: used by subagent/agent for skill execution
# EXECUTION_MODEL_ID=deepseek-v4-flash
# EXECUTION_MODEL_NAME=DeepSeek V4 Flash
# EXECUTION_BASE_URL=https://api.deepseek.com
# EXECUTION_PROVIDER=deepseek
# EXECUTION_REASONING=true
# EXECUTION_MAX_TOKENS=32768
# EXECUTION_THINKING_FORMAT=deepseek

# Router model: used for skill routing (lightweight, fast)
# ROUTER_MODEL_ID=deepseek-v4-flash
# ROUTER_MODEL_NAME=DeepSeek V4 Flash
# ROUTER_BASE_URL=https://api.deepseek.com
# ROUTER_PROVIDER=deepseek
# ROUTER_REASONING=false
# ROUTER_MAX_TOKENS=512

# Vision model: used for image caption / vision tasks (Gemini by default)
# VISION_MODEL_ID=gemini-3-flash-preview
# VISION_MODEL_NAME=Gemini 3 Flash Preview
# VISION_BASE_URL=https://nexus.alphacat.pro/v1
# VISION_PROVIDER=gemini
# VISION_REASONING=false
# VISION_MAX_TOKENS=8192

# --- Execution ---
# DEFAULT_TIMEOUT_MS=1800000
# MAX_CONCURRENT_TASKS=10
# CLEANUP_INTERVAL_MS=60000
# TASK_MAX_AGE_MS=3600000
# WRITE_FILE_MAX_LINES=800
# WRITE_FILE_MAX_CHARS=32000

# --- Workspace Cleanup ---
# WORKSPACE_MAX_AGE_DAYS=30
# WORKSPACE_MAX_COUNT=1000

# --- Data Directories ---
# DATA_DIR=./data
# DATABASE_PATH=./data/db/tasks.db
# WORKSPACE_ROOT=./data/tasks
# CONFIG_DIR=../config
# SKILLS_DIR=../skills

# --- Logging ---
# LOG_LEVEL=info
